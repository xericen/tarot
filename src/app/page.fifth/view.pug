.tarot-today
  // 히어로
  .tarot-today__hero(*ngIf="!showCards && !isResultView && !isLoading")
    .tarot-today__badge TODAY'S TAROT
    h1.tarot-today__title 오늘의 타로
    h2.tarot-today__title2 운세
    .tarot-today__hero-icon
      span.tarot-today__hero-emoji ✨
    p.tarot-today__desc 오늘 당신에게 어떤 메시지가 기다리고 있을까요?
    p.tarot-today__desc2 카드 한 장이 하루의 방향을 알려줄 거예요.

  // 입력 폼
  .tarot-today__form(*ngIf="!showCards && !isResultView && !isLoading")
    .tarot-today__panel
      label.tarot-today__label 이름을 입력해주세요
      input.tarot-today__input(type="text",
        [(ngModel)]="userName",
        (input)="service.render()",
        placeholder="당신의 이름")
      button.tarot-today__btn--primary(*ngIf="userName?.trim()",
        (click)="startSelection()") 카드 선택하기

  // 카드 선택 화면
  .tarot-today__select(*ngIf="showCards && !isResultView")
    .tarot-today__toolbar
      button.tarot-today__btn--secondary((click)="shuffleCards()") 카드 섞기

    .card-container
      .card-wrapper(*ngFor="let card of tarotCards; let i = index",
        [class.spread]="isSpread",
        [class.shuffling]="isShuffling",
        [class.gathering]="isGathering",
        [class.selected]="flippedCards[i]",
        [style.transitionDelay]="isSpread ? (i * 0.02) + 's' : '0s'",
        (click)="selectCard(i)")
        img.card([src]="flippedCards[i] ? '/assets/TarotCard/' + card + '.jpg' : getCardBackImage()",
          [class.reversed]="flippedCards[i] && reversedCards[i]",
          alt="타로 카드")

    .tarot-today__slot
      .tarot-today__slot-box
        img(*ngIf="selectedCard !== null",
          [src]="'/assets/TarotCard/' + selectedCard + '.jpg'",
          [class.reversed]="selectedReversed",
          alt="선택된 카드")
        span.tarot-today__slot-label(*ngIf="selectedCard === null") 오늘의 카드

    .tarot-today__confirm(*ngIf="selectedCard !== null")
      button.tarot-today__btn--primary((click)="showResult()") 결과 보기

  // 로딩
  .tarot-today__loading(*ngIf="isLoading && isResultView")
    .tarot-today__spinner
    p AI가 카드를 해석하고 있습니다...

  // 결과 화면
  .tarot-today__result(*ngIf="isResultView && cardInfo && !isLoading")
    .tarot-today__result-badge 오늘의 타로 결과
    .tarot-today__result-card
      .tarot-today__reversed-badge(*ngIf="cardInfo.is_reversed") Reversed
      img.tarot-today__result-img([src]="cardInfo.image_url", [alt]="cardInfo.card_name", [class.reversed]="cardInfo.is_reversed")
      h2.tarot-today__result-name {{ cardInfo.card_name }}

    .tarot-today__sections
      .tarot-today__section(*ngIf="cardInfo.keyword")
        .tarot-today__section-title 🔑 키워드
        .tarot-today__section-body {{ cardInfo.keyword }}

      .tarot-today__section(*ngIf="cardInfo.fortune")
        .tarot-today__section-title ✨ 오늘의 운세
        .tarot-today__section-body {{ cardInfo.fortune }}

      .tarot-today__section(*ngIf="cardInfo.guide_good || cardInfo.guide_caution")
        .tarot-today__section-title 📋 오늘의 행동 가이드
        .tarot-today__guide-item(*ngIf="cardInfo.guide_good")
          span.tarot-today__guide-label 👍 하기 좋은 일
          p.tarot-today__guide-text {{ cardInfo.guide_good }}
        .tarot-today__guide-item(*ngIf="cardInfo.guide_caution")
          span.tarot-today__guide-label ⚠️ 주의사항
          p.tarot-today__guide-text {{ cardInfo.guide_caution }}

      .tarot-today__section(*ngIf="cardInfo.lucky_color")
        .tarot-today__section-title 🎨 행운의 색
        .tarot-today__section-body {{ cardInfo.lucky_color }}

      .tarot-today__section(*ngIf="cardInfo.lucky_tip")
        .tarot-today__section-title 🍀 행운의 팁
        .tarot-today__section-body {{ cardInfo.lucky_tip }}

    button.tarot-today__btn--secondary((click)="restart()") 다시 보기

    wiz-component-card-chat([cardData]="cardData")

ng-container
  wiz-component-related
