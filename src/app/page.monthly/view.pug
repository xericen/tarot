.tarot-monthly
  // 히어로
  .tarot-monthly__hero(*ngIf="!showCards && !isResultView && !isLoading")
    .tarot-monthly__badge MONTHLY TAROT
    h1.tarot-monthly__title {{ currentMonth }}
    h2.tarot-monthly__title2 월간 타로 운세
    p.tarot-monthly__desc 이번 달 당신을 이끌어 줄 카드를 한 장 선택하세요
    .tarot-monthly__hero-icon
      span.tarot-monthly__hero-emoji 📅

  // 입력 폼
  .tarot-monthly__form(*ngIf="!showCards && !isResultView && !isLoading")
    .tarot-monthly__panel
      label.tarot-monthly__label 이름을 입력해주세요
      input.tarot-monthly__input(type="text",
        [(ngModel)]="userName",
        (input)="service.render()",
        placeholder="당신의 이름")

      label.tarot-monthly__label(style="margin-top: 16px;") 관심 분야를 선택해주세요
      select.tarot-monthly__input([(ngModel)]="concern")
        option(value="", disabled="", selected="") 선택하세요
        option(value="종합운") 종합운
        option(value="연애운") 연애운
        option(value="직업운") 직업운
        option(value="재정운") 재정운
        option(value="학업운") 학업운

      button.tarot-monthly__btn--primary(*ngIf="userName && concern",
        (click)="startSelection()") 카드 선택하기

  // 카드 선택
  .tarot-monthly__select(*ngIf="showCards && !isResultView && !isLoading")
    .tarot-monthly__toolbar
      button.tarot-monthly__btn--secondary((click)="shuffleCards()") 카드 섞기

    .card-container
      .card-wrapper(*ngFor="let card of tarotCards; let i = index",
        [class.spread]="isSpread",
        [class.shuffling]="isShuffling",
        [class.gathering]="isGathering",
        [class.selected]="flippedCards[i]",
        [style.transitionDelay]="isSpread ? (i * 0.02) + 's' : '0s'",
        (click)="selectCard(i)")
        img.card([src]="flippedCards[i] ? '/assets/TarotCard/' + card + '.jpg' : '/assets/images/CardB.png'",
          [class.reversed]="flippedCards[i] && reversedCards[i]",
          alt="타로 카드")

    .tarot-monthly__slot
      .tarot-monthly__slot-box
        img(*ngIf="selectedCard !== null",
          [src]="'/assets/TarotCard/' + selectedCard + '.jpg'",
          [class.reversed]="selectedReversed",
          alt="선택된 카드")
        span.tarot-monthly__slot-label(*ngIf="selectedCard === null") 이달의 카드

    .tarot-monthly__confirm(*ngIf="selectedCard !== null")
      button.tarot-monthly__btn--primary((click)="showResult()") 운세 확인하기

  // 로딩
  .tarot-monthly__loading(*ngIf="isLoading")
    .tarot-monthly__spinner
    p 이번 달 운세를 분석하고 있어요...

  // 결과
  .tarot-monthly__result(*ngIf="isResultView && result && !isLoading")
    .tarot-monthly__result-header
      .tarot-monthly__result-badge {{ result.month }} 월간 운세
      h2.tarot-monthly__result-title {{ userName }}님의 이달의 카드

    .tarot-monthly__result-card
      .tarot-monthly__reversed-badge(*ngIf="result.is_reversed") Reversed
      img.tarot-monthly__result-img([src]="result.image_url", [alt]="result.card_name", [class.reversed]="result.is_reversed")
      .tarot-monthly__result-card-info
        h3.tarot-monthly__result-name {{ result.card_name }}
        p.tarot-monthly__result-subtitle {{ result.subtitle }}

    // 키워드
    .tarot-monthly__keywords(*ngIf="result.keywords?.length")
      span.tarot-monthly__keyword(*ngFor="let kw of result.keywords") {{ kw }}

    // 섹션 탭
    .tarot-monthly__tabs
      button.tarot-monthly__tab([class.active]="activeSection === 'overview'",
        (click)="setSection('overview')") 종합
      button.tarot-monthly__tab([class.active]="activeSection === 'career'",
        (click)="setSection('career')") 직업
      button.tarot-monthly__tab([class.active]="activeSection === 'love'",
        (click)="setSection('love')") 애정
      button.tarot-monthly__tab([class.active]="activeSection === 'finance'",
        (click)="setSection('finance')") 재정
      button.tarot-monthly__tab([class.active]="activeSection === 'health'",
        (click)="setSection('health')") 건강

    // 섹션 내용
    .tarot-monthly__detail
      .tarot-monthly__detail-content(*ngIf="activeSection === 'overview'")
        .tarot-monthly__detail-icon 🔮
        .tarot-monthly__detail-title 이달의 종합 운세
        p.tarot-monthly__detail-text {{ result.overview }}
      .tarot-monthly__detail-content(*ngIf="activeSection === 'career'")
        .tarot-monthly__detail-icon 💼
        .tarot-monthly__detail-title 직업 · 학업
        p.tarot-monthly__detail-text {{ result.career }}
      .tarot-monthly__detail-content(*ngIf="activeSection === 'love'")
        .tarot-monthly__detail-icon 💕
        .tarot-monthly__detail-title 애정 · 인간관계
        p.tarot-monthly__detail-text {{ result.love }}
      .tarot-monthly__detail-content(*ngIf="activeSection === 'finance'")
        .tarot-monthly__detail-icon 💰
        .tarot-monthly__detail-title 재정 운세
        p.tarot-monthly__detail-text {{ result.finance }}
      .tarot-monthly__detail-content(*ngIf="activeSection === 'health'")
        .tarot-monthly__detail-icon 🏃
        .tarot-monthly__detail-title 건강 · 에너지
        p.tarot-monthly__detail-text {{ result.health }}

    // 조언
    .tarot-monthly__advice(*ngIf="result.advice")
      .tarot-monthly__advice-title ✦ 이달의 조언
      p.tarot-monthly__advice-text {{ result.advice }}

    // 행운의 날
    .tarot-monthly__lucky(*ngIf="result.lucky_day")
      span.tarot-monthly__lucky-label 🍀 행운의 날
      span.tarot-monthly__lucky-value {{ result.lucky_day }}

    // 한마디
    .tarot-monthly__closing(*ngIf="result.closing")
      .tarot-monthly__closing-title ✦ {{ userName }}님께 드리는 이달의 한마디
      p.tarot-monthly__closing-text {{ result.closing }}

    .tarot-monthly__result-action
      button.tarot-monthly__btn--secondary((click)="resetSelection()") 다시 보기

    wiz-component-card-chat([cardData]="cardData")

ng-container
  wiz-component-related
